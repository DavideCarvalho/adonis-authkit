{
  "name": "@adonis-agora/authkit-sdk",
  "version": "0.6.1",
  "description": "Backend SDK for the AuthKit Admin API with one typed interface and two drivers: remote (HTTP/Bearer) and embedded (in-process when the IdP runs in the same AdonisJS app).",
  "license": "MIT",
  "author": "dudousxd",
  "homepage": "https://github.com/DavideCarvalho/adonis-authkit/tree/main/packages/authkit-sdk#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/DavideCarvalho/adonis-authkit.git",
    "directory": "packages/authkit-sdk"
  },
  "bugs": {
    "url": "https://github.com/DavideCarvalho/adonis-authkit/issues"
  },
  "keywords": [
    "adonisjs",
    "authkit",
    "sdk",
    "admin-api",
    "oidc",
    "authentication"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./build/index.js",
  "types": "./build/index.d.ts",
  "files": [
    "build"
  ],
  "exports": {
    ".": "./build/index.js",
    "./types": "./build/index.js"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "node --import=@poppinss/ts-exec bin/test.ts"
  },
  "peerDependencies": {
    "@adonisjs/core": "catalog:adonisPeers",
    "@adonis-agora/authkit-server": ">=0.10.0"
  },
  "peerDependenciesMeta": {
    "@adonisjs/core": {
      "optional": true
    },
    "@adonis-agora/authkit-server": {
      "optional": true
    }
  },
  "devDependencies": {
    "@adonisjs/core": "catalog:adonis",
    "@adonis-agora/authkit-server": "workspace:*",
    "@adonisjs/tsconfig": "catalog:adonis",
    "@japa/assert": "catalog:",
    "@japa/runner": "catalog:",
    "@poppinss/ts-exec": "catalog:",
    "@types/node": "catalog:adonis",
    "typescript": "catalog:frontend"
  }
}
