{
  "name": "@adonis-agora/authkit-server",
  "version": "0.47.0",
  "description": "AdonisJS OIDC/OAuth2 provider (Identity Provider) toolkit: ejectable auth server with sessions, rate-limiting, MFA/TOTP, audit log, federated logout and OpenTelemetry metrics.",
  "license": "MIT",
  "author": "dudousxd",
  "homepage": "https://github.com/DavideCarvalho/adonis-authkit/tree/main/packages/authkit-server#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/DavideCarvalho/adonis-authkit.git",
    "directory": "packages/authkit-server"
  },
  "bugs": {
    "url": "https://github.com/DavideCarvalho/adonis-authkit/issues"
  },
  "keywords": [
    "adonisjs",
    "oidc",
    "oauth2",
    "openid-connect",
    "authentication",
    "authkit",
    "identity-provider",
    "rate-limiting",
    "mfa",
    "totp"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./build/index.js",
  "types": "./build/index.d.ts",
  "files": [
    "build",
    "stubs"
  ],
  "exports": {
    ".": "./build/index.js",
    "./types": "./build/index.js",
    "./services/main": "./build/services/main.js",
    "./durable": "./build/src/host/durable/index.js",
    "./telescope": "./build/src/observability/telescope/index.js",
    "./authkit_server_provider": "./build/providers/authkit_server_provider.js",
    "./commands": "./build/commands/main.js",
    "./commands/configure": "./build/commands/configure.js"
  },
  "adonisjs": {
    "types": "@adonis-agora/authkit-server",
    "providers": [
      "@adonis-agora/authkit-server/authkit_server_provider"
    ],
    "commands": [
      "@adonis-agora/authkit-server/commands"
    ]
  },
  "scripts": {
    "build": "node scripts/build_host_css.mjs && node scripts/build_webauthn.mjs && node scripts/build_ui.mjs && node -e \"const fs=require('node:fs');for(const d of ['build/stubs','build/host/views'])fs.rmSync(d,{recursive:true,force:true})\" && tsc && node -e \"require('node:fs').cpSync('src/host/assets','build/src/host/assets',{recursive:true})\" && node -e \"require('node:fs').cpSync('stubs','build/stubs',{recursive:true,filter:(s)=>!s.endsWith('.ts')})\" && node -e \"const fs=require('node:fs');if(fs.existsSync('assets'))fs.cpSync('assets','build/assets',{recursive:true})\" && node -e \"require('node:fs').cpSync('src/host/views','build/host/views',{recursive:true})\" && node -e \"const fs=require('node:fs');fs.mkdirSync('build/host/ui',{recursive:true});fs.readdirSync('src/host/ui').filter(f=>f.endsWith('.html')).forEach(f=>fs.copyFileSync('src/host/ui/'+f,'build/host/ui/'+f))\" && node -e \"require('node:fs').copyFileSync('commands/commands.json','build/commands/commands.json')\" && node -e \"const fs=require('node:fs');fs.mkdirSync('build/password',{recursive:true});fs.copyFileSync('src/password/common_passwords.txt','build/password/common_passwords.txt')\"",
    "prepack": "npm run build",
    "build:ui": "node scripts/build_ui.mjs",
    "build:webauthn": "node scripts/build_webauthn.mjs",
    "check:webauthn-bundle": "node scripts/check_webauthn_bundle.mjs",
    "typecheck": "tsc --noEmit && node scripts/typecheck_ui.mjs",
    "test": "node --import=@poppinss/ts-exec bin/test.ts",
    "build:host-css": "node scripts/build_host_css.mjs"
  },
  "peerDependencies": {
    "@adonis-agora/durable": "^0.2.0",
    "@adonis-agora/media": "^0.1.0",
    "@adonis-agora/telescope": "^0.1.0",
    "@adonisjs/ally": "catalog:adonisPeers",
    "@adonisjs/auth": "catalog:adonisPeers",
    "@adonisjs/core": "catalog:adonisPeers",
    "@adonisjs/drive": "catalog:adonisPeers",
    "@adonisjs/lock": "catalog:adonisPeers",
    "@adonisjs/lucid": "catalog:adonisPeers",
    "@adonisjs/redis": "catalog:adonisPeers",
    "@adonisjs/session": "catalog:adonisPeers",
    "@adonisjs/shield": "catalog:adonisPeers",
    "@vinejs/vine": "catalog:miscPeers",
    "edge.js": "catalog:miscPeers"
  },
  "peerDependenciesMeta": {
    "@adonis-agora/durable": {
      "optional": true
    },
    "@adonis-agora/media": {
      "optional": true
    },
    "@adonis-agora/telescope": {
      "optional": true
    },
    "edge.js": {
      "optional": true
    },
    "@adonisjs/ally": {
      "optional": true
    },
    "@adonisjs/auth": {
      "optional": true
    },
    "@adonisjs/drive": {
      "optional": true
    },
    "@adonisjs/lock": {
      "optional": true
    },
    "@adonisjs/redis": {
      "optional": true
    }
  },
  "dependencies": {
    "@adonis-agora/authkit-core": "workspace:*",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.1",
    "jose": "^5.9.0",
    "koa": "^3.2.1",
    "koa-mount": "^4.2.0",
    "oidc-provider": "^9.8.4",
    "otplib": "^12.0.1",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@adonis-agora/durable": "^0.2.0",
    "@adonis-agora/telescope": "^0.1.0",
    "@adonisjs/ally": "catalog:adonis",
    "@adonisjs/auth": "catalog:adonis",
    "@adonisjs/core": "catalog:adonis",
    "@adonisjs/drive": "catalog:adonis",
    "@adonisjs/lucid": "catalog:adonis",
    "@adonisjs/session": "catalog:adonis",
    "@adonisjs/shield": "catalog:adonis",
    "@adonisjs/tsconfig": "catalog:adonis",
    "@japa/assert": "catalog:",
    "@japa/runner": "catalog:",
    "@poppinss/ts-exec": "catalog:",
    "@types/koa": "^2.15.2",
    "@types/koa-mount": "^4.0.5",
    "@types/luxon": "catalog:adonis",
    "@types/node": "catalog:adonis",
    "@types/qrcode": "^1.5.5",
    "better-sqlite3": "^11.0.0",
    "edge.js": "catalog:",
    "esbuild": "0.25.12",
    "ioredis": "catalog:",
    "ioredis-mock": "^8.9.0",
    "luxon": "catalog:",
    "tailwindcss": "^3.4.19",
    "@vinejs/vine": "catalog:",
    "typescript": "catalog:frontend",
    "@vitejs/plugin-react": "catalog:",
    "@types/react": "catalog:frontend",
    "@types/react-dom": "catalog:frontend",
    "react": "catalog:frontend",
    "react-dom": "catalog:frontend",
    "vite": "catalog:",
    "@adonis-agora/authkit-react": "workspace:*",
    "@tanstack/react-query": "catalog:frontend",
    "react-error-boundary": "catalog:frontend",
    "nuqs": "2.8.9",
    "recharts": "3.8.1"
  }
}
