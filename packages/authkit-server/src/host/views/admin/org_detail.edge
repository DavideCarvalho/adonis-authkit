<!doctype html>
<html lang="pt-br"><head><meta charset="utf-8"><title>{{ t('admin.orgs.detail_title') }} — {{ org.name }}</title>
<script src="https://cdn.tailwindcss.com"></script></head>
<body class="min-h-screen bg-gray-100 p-4">
  <div class="mx-auto max-w-4xl">
    <div class="flex items-center justify-between py-6">
      <div>
        <div class="text-xs font-semibold uppercase tracking-widest text-gray-400">{{ t('common.brand_eyebrow') }}</div>
        <h1 class="text-xl font-semibold text-gray-900">{{ org.name }}</h1>
        <p class="text-xs text-gray-500">{{ org.slug }}</p>
      </div>
      <div class="flex items-center gap-4">
        <a href="/admin/orgs" class="text-sm text-gray-500 hover:underline">{{ t('admin.orgs.back') }}</a>
        <form method="POST" action="/account/logout">
          <input type="hidden" name="_csrf" value="{{ csrfToken }}">
          <button type="submit" class="text-sm text-gray-500 hover:underline">{{ t('admin.nav.logout') }}</button>
        </form>
      </div>
    </div>

    <nav class="mb-6 flex gap-4 text-sm font-medium">
      <a href="/admin" class="text-gray-500 hover:underline">{{ t('admin.nav.dashboard') }}</a>
      <a href="/admin/users" class="text-gray-500 hover:underline">{{ t('admin.nav.users') }}</a>
      <a href="/admin/orgs" class="text-gray-500 hover:underline">{{ t('admin.nav.orgs') }}</a>
      <a href="/admin/clients" class="text-gray-500 hover:underline">{{ t('admin.nav.clients') }}</a>
      <a href="/admin/audit" class="text-gray-500 hover:underline">{{ t('admin.nav.audit') }}</a>
      <a href="/admin/settings" class="text-gray-500 hover:underline">{{ t('admin.nav.settings') }}</a>
    </nav>

    @if(error)
      <div class="mb-4 rounded-lg border border-red-300 bg-red-50 p-3"><p class="text-sm font-medium text-red-900">{{ error }}</p></div>
    @end
    @if(success)
      <div class="mb-4 rounded-lg border border-emerald-300 bg-emerald-50 p-3"><p class="text-sm font-medium text-emerald-900">{{ success }}</p></div>
    @end

    {{-- Membros --}}
    <div class="mb-6 overflow-hidden rounded-xl bg-white shadow-sm ring-1 ring-black/5">
      <div class="border-b border-gray-100 p-4">
        <h2 class="text-sm font-semibold text-gray-900">{{ t('admin.orgs.members_section') }}</h2>
      </div>
      @if(org.members.length === 0)
        <p class="p-6 text-sm text-gray-500">{{ t('admin.orgs.members_empty') }}</p>
      @else
        @each(member in org.members)
          <div class="flex items-center justify-between border-b border-gray-100 p-4 last:border-0">
            <div>
              <p class="text-sm font-medium text-gray-900">{{ member.email ?? member.accountId }}</p>
              <p class="text-xs text-gray-500">{{ member.role }}</p>
            </div>
            <form method="POST" action="/admin/orgs/{{ org.id }}/members/{{ member.accountId }}/remove" class="inline"
              onsubmit="return confirm('{{ t('admin.orgs.member_remove_confirm') }}')">
              <input type="hidden" name="_csrf" value="{{ csrfToken }}">
              <button type="submit" class="text-sm text-red-700 hover:underline">{{ t('admin.orgs.remove_member') }}</button>
            </form>
          </div>
        @end
      @end
    </div>

    {{-- Adicionar membro --}}
    <div class="mb-6 rounded-xl bg-white p-4 shadow-sm ring-1 ring-black/5">
      <h2 class="mb-3 text-sm font-semibold text-gray-900">{{ t('admin.orgs.add_member_section') }}</h2>
      <form method="POST" action="/admin/orgs/{{ org.id }}/members" class="grid gap-2 sm:grid-cols-3">
        <input type="hidden" name="_csrf" value="{{ csrfToken }}">
        <select name="accountId" required class="rounded-lg border border-gray-300 px-3 py-2 text-sm outline-none focus:border-gray-900">
          <option value="">{{ t('admin.orgs.select_account') }}</option>
          @each(account in accounts)
            <option value="{{ account.id }}">{{ account.email }}</option>
          @end
        </select>
        <select name="role" class="rounded-lg border border-gray-300 px-3 py-2 text-sm outline-none focus:border-gray-900">
          @each(role in availableRoles)
            <option value="{{ role }}">{{ role }}</option>
          @end
        </select>
        <button type="submit" class="rounded-lg bg-gray-900 px-4 text-sm font-semibold text-white">
          {{ t('admin.orgs.add_member_submit') }}
        </button>
      </form>
    </div>

    {{-- Convites pendentes --}}
    @if(org.pendingInvitations.length > 0)
      <div class="mb-6 overflow-hidden rounded-xl bg-white shadow-sm ring-1 ring-black/5">
        <div class="border-b border-gray-100 p-4">
          <h2 class="text-sm font-semibold text-gray-900">{{ t('admin.orgs.invitations_section') }}</h2>
        </div>
        @each(inv in org.pendingInvitations)
          <div class="flex items-center justify-between border-b border-gray-100 p-4 last:border-0">
            <div>
              <p class="text-sm font-medium text-gray-900">{{ inv.email }}</p>
              <p class="text-xs text-gray-500">{{ inv.role }} · {{ t('admin.orgs.expires') }}: {{ inv.expiresAt }}</p>
            </div>
            <form method="POST" action="/admin/orgs/{{ org.id }}/invitations/{{ inv.id }}/revoke" class="inline">
              <input type="hidden" name="_csrf" value="{{ csrfToken }}">
              <button type="submit" class="text-sm text-red-700 hover:underline">{{ t('admin.orgs.revoke_invitation') }}</button>
            </form>
          </div>
        @end
      </div>
    @end

    {{-- Danger zone --}}
    <div class="rounded-xl bg-white p-4 shadow-sm ring-1 ring-red-200">
      <h2 class="mb-3 text-sm font-semibold text-red-900">{{ t('admin.orgs.danger_zone') }}</h2>
      <form method="POST" action="/admin/orgs/{{ org.id }}/delete"
        onsubmit="return confirm('{{ t('admin.orgs.delete_confirm') }}')">
        <input type="hidden" name="_csrf" value="{{ csrfToken }}">
        <button type="submit" class="rounded-lg bg-red-700 px-4 py-2 text-sm font-semibold text-white hover:bg-red-800">
          {{ t('admin.orgs.delete') }}
        </button>
      </form>
    </div>
  </div>
</body></html>
