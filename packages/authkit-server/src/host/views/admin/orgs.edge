    @if(!supported)
      <div class="rounded-xl bg-white p-6 shadow-sm ring-1 ring-black/5">
        <p class="text-sm text-gray-500">{{ t('admin.orgs.not_supported') }}</p>
      </div>
    @else
      <div class="mb-6 rounded-xl bg-white p-4 shadow-sm ring-1 ring-black/5">
        <h2 class="mb-3 text-sm font-semibold text-gray-900">{{ t('admin.orgs.create_section') }}</h2>
        <form method="POST" action="{{ adminBase }}/orgs" class="grid gap-2 sm:grid-cols-3">
          <input type="hidden" name="_csrf" value="{{ csrfToken }}">
          <input name="name" type="text" required placeholder="{{ t('admin.orgs.create_name_placeholder') }}"
            class="rounded-lg border border-gray-300 px-3 py-2 text-sm outline-none focus:border-gray-900" />
          <input name="slug" type="text" required placeholder="{{ t('admin.orgs.create_slug_placeholder') }}"
            class="rounded-lg border border-gray-300 px-3 py-2 text-sm outline-none focus:border-gray-900" />
          <button type="submit" class="rounded-lg bg-gray-900 px-4 text-sm font-semibold text-white">
            {{ t('admin.orgs.create_submit') }}
          </button>
        </form>
      </div>

      <div class="overflow-hidden rounded-xl bg-white shadow-sm ring-1 ring-black/5">
        @if(orgs.length === 0)
          <p class="p-6 text-sm text-gray-500">{{ t('admin.orgs.empty') }}</p>
        @else
          @each(org in orgs)
            <div class="border-b border-gray-100 p-4 last:border-0">
              <div class="flex items-center justify-between">
                <div>
                  <p class="text-sm font-medium text-gray-900">{{ org.name }}</p>
                  <p class="text-xs text-gray-500">{{ org.slug }} · {{ org.memberCount }} {{ t('admin.orgs.members_count') }}</p>
                </div>
                <div class="flex items-center gap-3 text-sm">
                  <a href="{{ adminBase }}/orgs/{{ org.id }}" class="text-gray-500 hover:underline">{{ t('admin.orgs.view') }}</a>
                  <form method="POST" action="{{ adminBase }}/orgs/{{ org.id }}/delete" class="inline"
                    onsubmit="return confirm('{{ t('admin.orgs.delete_confirm') }}')">
                    <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                    <button type="submit" class="font-semibold text-red-700 hover:underline">{{ t('admin.orgs.delete') }}</button>
                  </form>
                </div>
              </div>
            </div>
          @end
        @end
      </div>
