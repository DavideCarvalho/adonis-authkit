        <input type="hidden" name="_csrf" value="{{ csrfToken }}">
        <button type="submit" class="text-sm text-gray-500 hover:underline">{{ t('admin.nav.logout') }}</button>
      </form>
    </div>

    <nav class="mb-6 flex gap-4 text-sm font-medium">
      <a href="{{ adminBase }}" class="text-gray-500 hover:underline">{{ t('admin.nav.dashboard') }}</a>
      <a href="{{ adminBase }}/users" class="text-gray-500 hover:underline">{{ t('admin.nav.users') }}</a>
      <a href="{{ adminBase }}/roles" class="text-gray-900 underline">{{ t('admin.nav.roles') }}</a>
      <a href="{{ adminBase }}/clients" class="text-gray-500 hover:underline">{{ t('admin.nav.clients') }}</a>
      <a href="{{ adminBase }}/audit" class="text-gray-500 hover:underline">{{ t('admin.nav.audit') }}</a>
