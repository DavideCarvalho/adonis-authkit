    @if(error)
      <div class="mb-4 rounded-lg border border-red-300 bg-red-50 p-3"><p class="text-sm font-medium text-red-900">{{ error }}</p></div>
    @end
    @if(flash)
      <div class="mb-4 rounded-lg border border-emerald-300 bg-emerald-50 p-3"><p class="text-sm font-medium text-emerald-900">{{ flash }}</p></div>
    @end

    @if(!hasTable)
      <div class="rounded-xl bg-amber-50 p-5 ring-1 ring-amber-200">
        <p class="text-sm text-amber-800">{{ t('admin.roles.no_settings_table') }}</p>
      </div>
    @else

      {{-- Create new role --}}
      <div class="mb-6 rounded-xl bg-white p-6 shadow-sm ring-1 ring-black/5">
        <h2 class="mb-4 text-sm font-semibold text-gray-900">{{ t('admin.roles.create_section') }}</h2>
        <p class="mb-4 text-xs text-gray-500">{{ t('admin.roles.create_intro') }}</p>
        <form method="POST" action="{{ adminBase }}/roles" class="grid gap-2 sm:grid-cols-4">
          <input type="hidden" name="_csrf" value="{{ csrfToken }}">
          <input name="name" type="text" required
            placeholder="{{ t('admin.roles.name_placeholder') }}"
            pattern="[A-Z][A-Z0-9_]*"
            title="{{ t('admin.roles.name_pattern_hint') }}"
            class="rounded-lg border border-gray-300 px-3 py-2 text-sm uppercase outline-none focus:border-gray-900 sm:col-span-1" />
          <input name="description" type="text"
            placeholder="{{ t('admin.roles.description_placeholder') }}"
            class="rounded-lg border border-gray-300 px-3 py-2 text-sm outline-none focus:border-gray-900 sm:col-span-2" />
          <button type="submit" class="rounded-lg bg-gray-900 px-4 text-sm font-semibold text-white py-2">
            {{ t('admin.roles.create_submit') }}
          </button>
        </form>
      </div>

      {{-- Catalog list --}}
      <div class="overflow-hidden rounded-xl bg-white shadow-sm ring-1 ring-black/5">
        @if(catalog.length === 0)
          <p class="p-6 text-sm text-gray-500">{{ t('admin.roles.empty') }}</p>
        @else
          @each(role in catalog)
            <div class="border-b border-gray-100 p-4 last:border-0">
              <div class="flex items-start justify-between gap-4">
                <div>
                  <div class="flex items-center gap-2">
                    <p class="text-sm font-semibold text-gray-900 font-mono">{{ role.name }}</p>
                    @if(role.name === 'ADMIN')
                      <span class="rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-600">{{ t('admin.roles.protected_badge') }}</span>
                    @end
                  </div>
                  @if(role.description)
                    <p class="mt-0.5 text-xs text-gray-500">{{ role.description }}</p>
                  @end
                </div>
                <div class="flex items-center gap-3 shrink-0">
                  {{-- Edit description form (inline) --}}
                  <form method="POST" action="{{ adminBase }}/roles/{{ encodeURIComponent(role.name) }}/edit"
                    class="flex items-center gap-2">
                    <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                    <input name="description" type="text"
                      value="{{ role.description ?? '' }}"
                      placeholder="{{ t('admin.roles.description_placeholder') }}"
                      class="rounded-lg border border-gray-300 px-2 py-1 text-xs outline-none focus:border-gray-900 w-48" />
                    <button type="submit" class="text-xs text-gray-500 hover:underline whitespace-nowrap">
                      {{ t('admin.roles.save_description') }}
                    </button>
                  </form>
                  {{-- Delete (ADMIN: sem botão) --}}
                  @if(role.name !== 'ADMIN')
                    <form method="POST" action="{{ adminBase }}/roles/{{ encodeURIComponent(role.name) }}/delete"
                      class="inline"
                      onsubmit="return confirm('{{ t('admin.roles.delete_confirm', { name: role.name }) }}')">
                      <input type="hidden" name="_csrf" value="{{ csrfToken }}">
                      <button type="submit" class="text-xs font-semibold text-red-700 hover:underline whitespace-nowrap">
                        {{ t('admin.roles.delete') }}
                      </button>
                    </form>
                  @end
                </div>
              </div>
            </div>
          @end
        @end
      </div>

      <p class="mt-4 text-xs text-gray-400">{{ t('admin.roles.delete_note') }}</p>

    @end
  </div>
</body></html>
