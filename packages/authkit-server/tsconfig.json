{
  "extends": "@adonisjs/tsconfig/tsconfig.package.json",
  "compilerOptions": {
    "rootDir": "./",
    "outDir": "./build",
    "module": "NodeNext",
    "moduleResolution": "NodeNext"
  },
  "include": [
    "index.ts",
    "types.ts",
    "src/**/*",
    "providers/**/*",
    "commands/**/*",
    "database/**/*",
    "services/**/*",
    "stubs/**/*"
  ],
  "exclude": ["stubs/ui/**/*"]
}
