{
  "name": "@adonis-agora/authkit-testing",
  "version": "0.4.0",
  "description": "Test helpers for apps built on AuthKit: mint real signed ID tokens with a local JWKS, fake authenticators and account stores, and build valid identities — so host apps can test auth flows without booting an IdP.",
  "license": "MIT",
  "author": "dudousxd",
  "homepage": "https://github.com/DavideCarvalho/adonis-authkit/tree/main/packages/authkit-testing#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/DavideCarvalho/adonis-authkit.git",
    "directory": "packages/authkit-testing"
  },
  "bugs": {
    "url": "https://github.com/DavideCarvalho/adonis-authkit/issues"
  },
  "keywords": [
    "adonisjs",
    "authentication",
    "authkit",
    "testing",
    "jwt",
    "jwks",
    "oidc"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./build/index.js",
  "types": "./build/index.d.ts",
  "files": [
    "build"
  ],
  "exports": {
    ".": "./build/index.js",
    "./types": "./build/index.js"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "node --import=@poppinss/ts-exec bin/test.ts"
  },
  "dependencies": {
    "@adonis-agora/authkit-core": "workspace:*",
    "jose": "^5.9.0"
  },
  "devDependencies": {
    "@adonis-agora/authkit-client": "workspace:*",
    "@adonisjs/tsconfig": "catalog:adonis",
    "@japa/assert": "catalog:",
    "@japa/runner": "catalog:",
    "@poppinss/ts-exec": "catalog:",
    "@types/node": "catalog:adonis",
    "typescript": "catalog:frontend"
  }
}
