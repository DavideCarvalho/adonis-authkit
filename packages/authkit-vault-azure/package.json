{
  "name": "@dudousxd/adonis-authkit-vault-azure",
  "version": "0.1.0",
  "description": "Azure Key Vault keystore vault for the AuthKit JWKS keystore (createKeystoreVault).",
  "license": "MIT",
  "author": "dudousxd",
  "homepage": "https://github.com/DavideCarvalho/adonis-authkit/tree/main/packages/authkit-vault-azure#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/DavideCarvalho/adonis-authkit.git",
    "directory": "packages/authkit-vault-azure"
  },
  "bugs": {
    "url": "https://github.com/DavideCarvalho/adonis-authkit/issues"
  },
  "keywords": [
    "adonisjs",
    "authkit",
    "keystore",
    "jwks",
    "azure",
    "key-vault"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./build/index.js",
  "types": "./build/index.d.ts",
  "files": [
    "build"
  ],
  "exports": {
    ".": "./build/index.js",
    "./types": "./build/index.js"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "node --import=@poppinss/ts-exec bin/test.ts"
  },
  "peerDependencies": {
    "@azure/keyvault-secrets": ">=4",
    "@azure/identity": ">=4"
  },
  "peerDependenciesMeta": {
    "@azure/keyvault-secrets": {
      "optional": true
    },
    "@azure/identity": {
      "optional": true
    }
  },
  "devDependencies": {
    "@adonisjs/tsconfig": "catalog:adonis",
    "@japa/assert": "catalog:",
    "@japa/runner": "catalog:",
    "@poppinss/ts-exec": "catalog:",
    "@types/node": "catalog:adonis",
    "typescript": "catalog:frontend"
  }
}
